# ===================================================
# DUBBLE BET — Variables d'environnement (.env)
# Copiez ce fichier en .env et remplissez les valeurs
# Ne commitez JAMAIS le fichier .env
# ===================================================

# ─── Supabase ────────────────────────────────────────
SUPABASE_URL=https://VOTRE_PROJECT_ID.supabase.co
SUPABASE_SERVICE_KEY=VOTRE_SERVICE_ROLE_KEY

# ─── Stripe ──────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_VOTRE_CLE_SECRETE
STRIPE_WEBHOOK_SECRET=whsec_VOTRE_WEBHOOK_SECRET

# Price IDs Stripe (créez les produits dans le Dashboard Stripe)
STRIPE_PRICE_STARTER=price_STARTER_ID
STRIPE_PRICE_PRO=price_PRO_ID
STRIPE_PRICE_ILLIMITE=price_ILLIMITE_ID
STRIPE_PRICE_UNIT=price_UNIT_ID

# ─── API-Sports ──────────────────────────────────────
# Obtenez votre clé sur https://rapidapi.com/api-sports/api/api-football
API_SPORTS_KEY=VOTRE_CLE_API_SPORTS

# ─── Modèle Python (Flask) ───────────────────────────
PYTHON_API_URL=http://localhost:5000
# En production : https://VOTRE_APP_FLASK.railway.app
INTERNAL_API_TOKEN=votre-token-interne-securise

# ─── Général ─────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5500
# En production : https://votre-site.vercel.app
